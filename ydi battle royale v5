          <div style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,marginBottom:14,boxShadow:T.shadow}}>
            <div style={{display:"flex",justifyContent:"space-between",marginBottom:12}}><div style={{fontSize:14,fontWeight:700}}>🏆 Team Goals</div><div style={{display:"flex",gap:14,fontSize:12}}><span style={{color:"#059669",fontWeight:700}}>{fmtPrice(teamRev)}</span><span style={{color:"#6366f1",fontWeight:700}}>{teamPols} policies</span></div></div>
            <div style={{display:"flex",gap:5,marginBottom:12}}>{TEAM_GOALS.map((g,i)=>{const ok=teamRev>=g.target;return <div key={i} style={{flex:1,textAlign:"center",padding:"8px 3px",background:ok?"#fffbeb":T.bgSubtle,borderRadius:10,border:ok?"1px solid #fde68a":`1px solid ${T.borderLight}`,opacity:ok?1:0.5}}><div style={{fontSize:18}}>{g.icon}</div><div style={{fontSize:8,fontWeight:700,color:ok?g.color:T.textMuted,marginTop:2}}>{g.name}</div><div style={{fontSize:8,color:T.textMuted}}>${g.target/1000}K</div></div>;})}</div>
            {teamGoalTier.next&&<><div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:T.textSec,marginBottom:4}}><span>{teamGoalTier.current?`${teamGoalTier.current.icon} ${teamGoalTier.current.name}`:"🏁 Start"}</span><span>${(teamGoalTier.next.target-teamRev).toLocaleString()} to {teamGoalTier.next.name}</span></div><MiniBar value={teamRev} max={teamGoalTier.next.target} color="#f59e0b" height={8} T={T}/></>}
          </div>
          {/* Stats */}
          <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8,marginBottom:14}}>
            {[{l:"Premium",v:fmtPrice(rev),s:rTier.current?`${rTier.current.icon} ${rTier.current.name}`:"🏁 Unranked",c:"#059669"},{l:"Policies",v:pols,s:pTier.current?`${pTier.current.icon} ${pTier.current.name}`:"🏁 Start",c:agent.color},{l:"Streak",v:`${streak.current}wk`,s:`Best: ${streak.best}wk`,c:"#d97706"},{l:"Avg Bind",v:avgBind?`${avgBind}d`:"—",s:avgBind?"Lead→Bound":"",c:"#7c3aed"}].map((c,i)=><div key={i} style={{background:T.bgCard,borderRadius:14,padding:"14px 12px",border:`1px solid ${T.border}`,position:"relative",overflow:"hidden",boxShadow:T.shadow}}><div style={{position:"absolute",top:0,left:0,right:0,height:3,background:c.c}}/><div style={{fontSize:9,color:T.textMuted,textTransform:"uppercase",letterSpacing:1.5,marginBottom:3}}>{c.l}</div><div style={{fontSize:18,fontWeight:800,marginBottom:1}}>{c.v}</div><div style={{fontSize:10,color:c.c,fontWeight:600}}>{c.s}</div></div>)}
          </div>
          {/* Revenue Rank */}
          <div style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,marginBottom:14,boxShadow:T.shadow}}>
            <div style={{fontSize:14,fontWeight:700,marginBottom:14}}>🏅 Revenue Rank</div>
            <div style={{display:"flex",gap:6,marginBottom:14}}>{revTiers.map((t,i)=>{const ok=rev>=t.target;return <div key={i} style={{flex:1,textAlign:"center",padding:"8px 3px",background:ok?`${agent.color}08`:T.bgSubtle,borderRadius:10,border:ok?`1px solid ${agent.color}33`:`1px solid ${T.borderLight}`,opacity:ok?1:0.4}}><div style={{fontSize:20}}>{t.icon}</div><div style={{fontSize:9,fontWeight:600,color:ok?agent.color:T.textMuted,marginTop:3}}>{t.name}</div><div style={{fontSize:8,color:T.textMuted}}>${t.target/1000}K</div></div>;})}</div>
            {rTier.next&&<><div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:T.textSec,marginBottom:4}}><span>{rTier.current?.name||"Start"}</span><span>${(rTier.next.target-rev).toLocaleString()} to {rTier.next.name}</span></div><MiniBar value={rev} max={rTier.next.target} color={agent.color} height={8} T={T}/></>}
          </div>
          {/* Recent Wins */}
          <div style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,boxShadow:T.shadow}}>
            <div style={{fontSize:14,fontWeight:700,marginBottom:12}}>⚡ Recent Wins</div>
            {sales.length===0?<div style={{textAlign:"center",padding:"24px 0",color:T.textMuted}}><div style={{fontSize:32,marginBottom:6}}>🚀</div><div style={{fontSize:13,fontWeight:600}}>No policies in this period!</div></div>
            :[...sales].reverse().slice(0,6).map((s,i)=><div key={i} style={{display:"flex",alignItems:"center",gap:10,padding:"9px 10px",borderRadius:10,marginBottom:5,background:T.bgSubtle,border:`1px solid ${T.borderLight}`}}>
              <div style={{width:32,height:32,borderRadius:9,background:s.price>=5000?"#fef3c7":`${agent.color}10`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:14}}>{s.price>=10000?"🐋":s.price>=5000?"💰":"✅"}</div>
              <div style={{flex:1}}><div style={{fontSize:12,fontWeight:600}}>{(s.name||"").split(" - ")[0]}</div><div style={{fontSize:10,color:T.textMuted}}>{s.type} · {s.platform} · {s.boundDate}</div></div>
              <div style={{fontSize:13,fontWeight:700,color:s.price>=5000?"#b45309":"#059669"}}>{fmtPrice(s.price)}</div></div>)}
          </div>
        </div>}

        {/* ====== LEADERBOARD ====== */}
        {tab==="leaderboard"&&<div style={{animation:"slideUp 0.4s"}}>
          {/* Race Tracks */}
          <RaceTrack agents={agents} field="totalRevenue" maxVal={maxTeamRev} icon="🏎️" title="🏎️ Premium Race" T={T}/>
          <RaceTrack agents={agents} field="totalPolicies" maxVal={maxTeamPol} icon="🐴" title="🐴 Policy Derby" T={T}/>
          {/* Revenue Rankings */}
          <div style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,marginBottom:14,boxShadow:T.shadow}}>
            <div style={{fontSize:14,fontWeight:700,marginBottom:14}}>🏅 Revenue Rankings — {curPeriod?.name||"All Time"}</div>
            {sorted.map((a,i)=>{const tier=getTier(revTiers,a.totalRevenue),aXP=calcXP(a.sales),aLvl=getLevel(aXP),isMe=a.id===selAgent;return(
              <div key={a.id} onClick={()=>setSelAgent(a.id)} style={{display:"flex",alignItems:"center",gap:12,padding:"12px 14px",borderRadius:14,marginBottom:8,background:isMe?`${a.color}06`:T.bgSubtle,border:isMe?`1px solid ${a.color}33`:`1px solid ${T.borderLight}`,cursor:"pointer"}}>
                <div style={{width:34,height:34,borderRadius:10,background:i===0?"linear-gradient(135deg,#fbbf24,#f59e0b)":i===1?"linear-gradient(135deg,#d1d5db,#9ca3af)":i===2?"linear-gradient(135deg,#d97706,#b45309)":T.bgSubtle,display:"flex",alignItems:"center",justifyContent:"center",fontSize:16}}>{rankEmojis[i]||`${i+1}`}</div>
                <div style={{width:40,height:40,borderRadius:12,background:`${a.color}10`,border:`2px solid ${a.color}33`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:20}}>{a.avatar}</div>
                <div style={{flex:1}}><div style={{display:"flex",alignItems:"center",gap:6}}><span style={{fontSize:13,fontWeight:700,color:isMe?a.color:T.text}}>{a.name}</span>{i===0&&a.totalRevenue>0&&<span style={{fontSize:9,background:"#f59e0b",color:"#fff",padding:"2px 8px",borderRadius:6,fontWeight:800}}>LEADER</span>}</div><div style={{display:"flex",gap:10,fontSize:10,color:T.textMuted,marginTop:2}}><span>Lvl {aLvl.current.level}</span><span>{a.totalPolicies} pol</span><span>{tier.current?`${tier.current.icon} ${tier.current.name}`:"—"}</span></div><div style={{marginTop:5}}><MiniBar value={a.totalRevenue} max={maxTeamRev} color={a.color} height={4} T={T}/></div></div>
                <div style={{textAlign:"right"}}><div style={{fontSize:16,fontWeight:800,color:i===0?"#b45309":T.text}}>{fmtPrice(a.totalRevenue)}</div><div style={{fontSize:10,color:a.color,fontWeight:600}}>{aXP.toLocaleString()} XP</div></div>
              </div>);})}
          </div>
          {/* Life Leader */}
          <div style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,marginBottom:14,boxShadow:T.shadow}}>
            <div style={{fontSize:14,fontWeight:700,marginBottom:14}}>❤️ Life Sales Leader</div>
            {lifeBoard.map((a,i)=><div key={a.id} style={{display:"flex",alignItems:"center",gap:10,padding:"8px 12px",borderRadius:10,marginBottom:5,background:i===0&&a.lifePrem>0?"#fdf2f8":T.bgSubtle,border:i===0&&a.lifePrem>0?"1px solid #fbcfe8":`1px solid ${T.borderLight}`}}><span style={{fontSize:16}}>{a.avatar}</span><div style={{flex:1}}><div style={{fontSize:12,fontWeight:700,color:a.color}}>{a.name.split(" ")[0]}</div><div style={{fontSize:10,color:T.textMuted}}>{a.lifeCount} policies</div></div><div style={{fontSize:14,fontWeight:800,color:a.lifePrem>0?"#db2777":T.textMuted}}>{fmtPrice(a.lifePrem)}</div>{i===0&&a.lifePrem>0&&<span style={{fontSize:8,background:"#db2777",color:"#fff",padding:"2px 6px",borderRadius:4,fontWeight:700}}>LEADER</span>}</div>)}
          </div>
          {/* Head to Head */}
          <div style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,boxShadow:T.shadow}}>
            <div style={{fontSize:14,fontWeight:700,marginBottom:14}}>📊 Head-to-Head</div>
            <div style={{display:"grid",gridTemplateColumns:`repeat(${agents.length},1fr)`,gap:6}}>
              {agents.map(a=>{const aXP=calcXP(a.sales),aB=getBadges(a.sales).filter(x=>x.earned).length,isL=sorted[0]?.id===a.id;return(
                <div key={a.id} style={{padding:"12px 8px",borderRadius:12,textAlign:"center",background:isL?`${a.color}06`:T.bgSubtle,border:isL?`2px solid ${a.color}33`:`1px solid ${T.borderLight}`,position:"relative"}}>
                  {isL&&<div style={{position:"absolute",top:-8,left:"50%",transform:"translateX(-50%)",fontSize:12}}>👑</div>}
                  <div style={{fontSize:22,marginBottom:3}}>{a.avatar}</div><div style={{fontSize:10,fontWeight:700,color:a.color,marginBottom:6}}>{a.name.split(" ")[0]}</div>
                  {[{l:"Premium",v:`$${(a.totalRevenue/1000).toFixed(1)}K`},{l:"Policies",v:a.totalPolicies},{l:"Badges",v:`${aB}/16`},{l:"XP",v:aXP.toLocaleString()}].map((r,j)=><div key={j}><div style={{fontSize:9,color:T.textMuted}}>{r.l}</div><div style={{fontSize:12,fontWeight:800,marginBottom:4,color:j===3?a.color:T.text}}>{r.v}</div></div>)}
                </div>);})}
            </div>
          </div>
        </div>}

        {/* ====== BADGES ====== */}
        {tab==="achievements"&&<div style={{animation:"slideUp 0.4s"}}>
          <div style={{display:"flex",justifyContent:"space-between",marginBottom:16,padding:"12px 16px",background:T.bgCard,borderRadius:14,border:`1px solid ${T.border}`,boxShadow:T.shadow}}><div><span style={{fontSize:22,fontWeight:800}}>{earned}</span><span style={{fontSize:13,color:T.textMuted}}> / {badges.length}</span></div><div style={{fontSize:12,color:agent.color,fontWeight:600}}>{earned*250} XP</div></div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8}}>
            {badges.map((b,i)=><div key={i} onMouseEnter={()=>setHoverBadge(i)} onMouseLeave={()=>setHoverBadge(null)} style={{padding:"14px 10px",borderRadius:14,textAlign:"center",background:b.earned?T.bgCard:T.bgSubtle,border:b.earned?`1px solid ${agent.color}33`:`1px solid ${T.borderLight}`,opacity:b.earned?1:0.4,transform:hoverBadge===i?"translateY(-3px) scale(1.02)":"none",transition:"all 0.25s",cursor:"default",position:"relative",boxShadow:b.earned?T.shadow:"none"}}>
              <div style={{fontSize:26,marginBottom:3,filter:b.earned?"none":"grayscale(1)"}}>{b.icon}</div><div style={{fontSize:10,fontWeight:700,color:b.earned?T.text:T.textMuted,marginBottom:1}}>{b.name}</div><div style={{fontSize:8,color:T.textMuted}}>{b.desc}</div>
              {b.earned&&<div style={{position:"absolute",top:4,right:4,fontSize:7,background:"#059669",color:"#fff",padding:"1px 4px",borderRadius:4,fontWeight:700}}>+250</div>}
            </div>)}
          </div>
        </div>}

        {/* ====== BREAKDOWN ====== */}
        {tab==="breakdown"&&<div style={{display:"flex",flexDirection:"column",gap:14,animation:"slideUp 0.4s"}}>
          {sales.length===0?<div style={{background:T.bgCard,borderRadius:16,padding:"36px 20px",border:`1px solid ${T.border}`,textAlign:"center"}}><div style={{fontSize:44,marginBottom:10}}>📭</div><div style={{fontSize:15,fontWeight:700,color:T.textMuted}}>No data in this period</div></div>
          :<>{[{title:"📊 Premium by Type",data:typeBreak,fmt:v=>fmtPrice(v)},{title:"🌐 Policies by Platform",data:platBreak,fmt:v=>`${v}`},...(Object.keys(leadBreak).length>0?[{title:"📍 By Lead Source",data:leadBreak,fmt:v=>`${v}`}]:[])].map((sec,si)=>
            <div key={si} style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,boxShadow:T.shadow}}><div style={{fontSize:14,fontWeight:700,marginBottom:14}}>{sec.title}</div>
              {Object.entries(sec.data).sort(([,a],[,b])=>b-a).map(([k,v],i)=><div key={i} style={{marginBottom:10}}><div style={{display:"flex",justifyContent:"space-between",fontSize:11,marginBottom:3}}><span style={{color:T.textSec,fontWeight:600}}>{k}</span><span style={{color:barColors[i%barColors.length],fontWeight:700}}>{sec.fmt(v)}</span></div><MiniBar value={v} max={Math.max(...Object.values(sec.data))} color={barColors[i%barColors.length]} T={T}/></div>)}</div>)}
            <div style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,boxShadow:T.shadow}}>
              <div style={{fontSize:14,fontWeight:700,marginBottom:12}}>🏆 Top Deals</div>
              {[...sales].sort((a,b)=>b.price-a.price).slice(0,5).map((s,i)=><div key={i} style={{display:"flex",alignItems:"center",gap:10,padding:"8px 10px",borderRadius:10,marginBottom:5,background:i===0?"#fffbeb":T.bgSubtle,border:i===0?"1px solid #fde68a":`1px solid ${T.borderLight}`}}>
                <div style={{width:26,height:26,borderRadius:8,background:i===0?"#f59e0b":i===1?"#9ca3af":i===2?"#b45309":T.bgSubtle,display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:800,color:i<3?"#fff":T.textMuted}}>{i+1}</div>
                <div style={{flex:1}}><div style={{fontSize:12,fontWeight:600}}>{(s.name||"").split(" - ")[0]}</div><div style={{fontSize:9,color:T.textMuted}}>{s.type}</div></div>
                <div style={{fontSize:14,fontWeight:800,color:i===0?"#b45309":T.text}}>{fmtPrice(s.price)}</div></div>)}
            </div></>}
        </div>}

        {/* ====== QUESTS ====== */}
        {tab==="quests"&&<div style={{animation:"slideUp 0.4s"}}>
          <div style={{padding:"14px 16px",marginBottom:14,background:`${agent.color}06`,borderRadius:14,border:`1px solid ${agent.color}22`}}><div style={{fontSize:14,fontWeight:700,marginBottom:3}}>⚔️ Quest Board — {agent.name.split(" ")[0]}</div><div style={{fontSize:11,color:T.textSec}}>{quests.filter(q=>q.progress>=q.target).length}/{quests.length} completed</div></div>
          {questCats.map(cat=>{const cq=quests.filter(q=>q.cat===cat);return <div key={cat} style={{marginBottom:14}}>
            <div style={{fontSize:12,fontWeight:700,color:T.textSec,marginBottom:6,padding:"0 3px"}}>{cat}</div>
            {cq.map((q,i)=>{const pct=q.target>0?Math.min((q.progress/q.target)*100,100):0,done=pct>=100;return(
              <div key={i} style={{padding:"12px 14px",borderRadius:12,marginBottom:6,background:done?"#f0fdf4":T.bgCard,border:done?"1px solid #bbf7d0":`1px solid ${T.border}`,boxShadow:T.shadow}}>
                <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:6}}><div style={{width:32,height:32,borderRadius:9,background:done?"#dcfce7":`${agent.color}08`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:16}}>{done?"✅":q.icon}</div>
                  <div style={{flex:1}}><div style={{fontSize:12,fontWeight:700,color:done?"#059669":T.text}}>{q.name}</div><div style={{fontSize:9,color:T.textMuted}}>Reward: {q.reward}</div></div>
                  <div style={{fontSize:11,fontWeight:800,color:done?"#059669":agent.color}}>{pct.toFixed(0)}%</div></div>
                <MiniBar value={q.progress} max={q.target} color={done?"#059669":agent.color} height={4} T={T}/>
                <div style={{display:"flex",justifyContent:"space-between",marginTop:2,fontSize:9,color:T.textMuted}}><span>{q.progress>100?`$${q.progress.toLocaleString()}`:q.progress}/{q.target>100?`$${q.target.toLocaleString()}`:q.target}</span>{done&&<span style={{color:"#059669",fontWeight:700}}>DONE!</span>}</div>
              </div>);})}
          </div>;})}
        </div>}

        {/* ====== REVIEWS ====== */}
        {tab==="reviews"&&<div style={{animation:"slideUp 0.4s"}}>
          {/* Per-agent summary with premium + policies */}
          <div style={{display:"grid",gridTemplateColumns:`repeat(${Math.min(agents.length,4)},1fr)`,gap:10,marginBottom:16}}>
            {agents.map(a=>{const revs=a.sales.filter(s=>s.review&&s.review.trim());return(
              <div key={a.id} style={{background:T.bgCard,borderRadius:14,padding:16,border:`1px solid ${T.border}`,boxShadow:T.shadow,textAlign:"center"}}>
                <div style={{fontSize:26,marginBottom:4}}>{a.avatar}</div>
                <div style={{fontSize:12,fontWeight:700,color:a.color,marginBottom:8}}>{a.name.split(" ")[0]}</div>
                <div style={{fontSize:18,fontWeight:800,color:"#059669",marginBottom:2}}>{fmtPrice(a.totalRevenue)}</div>
                <div style={{fontSize:10,color:T.textMuted,marginBottom:6}}>{a.totalPolicies} policies</div>
                <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:4}}>
                  <span style={{fontSize:16}}>⭐</span>
                  <span style={{fontSize:14,fontWeight:800}}>{revs.length}</span>
                  <span style={{fontSize:10,color:T.textMuted}}>reviews</span>
                </div>
              </div>);})}
          </div>
          {/* All reviews */}
          <div style={{background:T.bgCard,borderRadius:16,padding:18,border:`1px solid ${T.border}`,boxShadow:T.shadow}}>
            <div style={{fontSize:14,fontWeight:700,marginBottom:14}}>⭐ Customer Reviews ({allReviews.length})</div>
            {allReviews.length===0?<div style={{textAlign:"center",padding:"30px 0",color:T.textMuted}}><div style={{fontSize:36,marginBottom:8}}>💬</div><div style={{fontSize:13,fontWeight:600}}>No reviews yet. Add a "Review" column to your spreadsheet!</div></div>
            :allReviews.map((r,i)=><div key={i} style={{padding:"12px 14px",borderRadius:12,marginBottom:8,background:T.bgSubtle,border:`1px solid ${T.borderLight}`}}>
              <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:6}}>
                <span style={{fontSize:18}}>{r.agentAvatar}</span>
                <div style={{flex:1}}><div style={{fontSize:12,fontWeight:700,color:r.agentColor}}>{r.agentName}</div><div style={{fontSize:10,color:T.textMuted}}>{r.name} · {r.type} · {fmtPrice(r.price)} · {r.boundDate}</div></div>
                <span style={{fontSize:14}}>⭐</span>
              </div>
              <div style={{fontSize:12,color:T.textSec,fontStyle:"italic",lineHeight:1.5,padding:"4px 0 0 28px"}}>"{r.review}"</div>
            </div>)}
          </div>
        </div>}

        {/* FOOTER */}
        <div style={{marginTop:20,padding:"12px 16px",background:T.bgCard,borderRadius:12,border:`1px solid ${T.border}`,display:"flex",justifyContent:"space-between",fontSize:10,color:T.textMuted,flexWrap:"wrap",gap:6}}>
          <span>📡 {agents.length} Producers · {fmtPrice(teamRev)} / {teamPols} pol</span>
          <span>{curPeriod?.name||"All Time"} · {agent.name} · #{rankOf} · {earned}/{badges.length} Badges</span>
        </div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);

</script>
</body>
</html>
