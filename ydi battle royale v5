/* ===== PERSISTENCE ===== */
function loadLS(k,d){try{const s=localStorage.getItem(k);if(s){const p=JSON.parse(s);if(p)return p;}}catch(e){}return d;}
function saveLS(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}}

/* ===== PERIODS ===== */
function getCurPeriodIdx(periods){const t=new Date();t.setHours(0,0,0,0);for(let i=0;i<periods.length;i++){const s=new Date(periods[i].start+"T00:00:00"),e=new Date(periods[i].end+"T23:59:59");if(t>=s&&t<=e)return i;}let l=-1;for(let i=0;i<periods.length;i++){if(t>new Date(periods[i].end+"T23:59:59"))l=i;}return l>=0?l:0;}
function filterByPeriod(sales,p){if(!p)return sales;const s=new Date(p.start+"T00:00:00"),e=new Date(p.end+"T23:59:59");return sales.filter(x=>x.boundDateObj&&x.boundDateObj>=s&&x.boundDateObj<=e);}

/* ===== FETCH ===== */
async function fetchCSV(sheetId,gid){const sid=sheetId||MASTER_SHEET_ID;const urls=[`https://docs.google.com/spreadsheets/d/${sid}/export?gid=${gid}&format=csv`,`https://docs.google.com/spreadsheets/d/${sid}/gviz/tq?tqx=out:csv&gid=${gid}`];for(const u of urls){try{const r=await fetch(u,{redirect:'follow'});if(!r.ok)continue;const t=await r.text();if(t&&t.length>10&&!t.startsWith("<!DOCTYPE"))return t;}catch(e){}}return null;}

/* ===== SOUND ===== */
function playSound(id){const s=SOUND_OPTIONS.find(x=>x.id===id)||SOUND_OPTIONS[0];try{const ctx=new(window.AudioContext||window.webkitAudioContext)();s.freqs.forEach((f,i)=>{const o=ctx.createOscillator(),g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.type="sine";o.frequency.value=f;const st=ctx.currentTime+i*0.12;g.gain.setValueAtTime(0.15,st);g.gain.exponentialRampToValueAtTime(0.001,st+0.4);o.start(st);o.stop(st+0.4);});}catch(e){}}

/* ===== CSV ===== */
function findCol(h,c){const hl=h.map(x=>x.toLowerCase().trim());for(const k of c){const i=hl.findIndex(x=>x.includes(k.toLowerCase()));if(i>=0)return h[i];}return null;}
function parseDate(s){if(!s)return null;const p=s.split("/");if(p.length>=3)return new Date(p[2],p[0]-1,p[1]);const d=new Date(s);return isNaN(d)?null:d;}
function daysBetween(a,b){if(!a||!b)return null;return Math.round(Math.abs(b-a)/86400000);}
function parseRows(rows,headers){
  const nC=findCol(headers,["name","NAME","client"]),sC=findCol(headers,["status"]),bC=findCol(headers,["bound date","bound"]),eC=findCol(headers,["effective date","effective"]),pC=findCol(headers,["price","premium"]),plC=findCol(headers,["sales platform","platform","carrier"]),tC=findCol(headers,["type of insurance","type","line"]),poC=findCol(headers,["policy number","policy"]),rC=findCol(headers,["referral","ref"]),lsC=findCol(headers,["lead source","lead_source","source"]),ldC=findCol(headers,["lead date","lead_date"]),rvC=findCol(headers,["review","reviews","rating","customer review"]);
  return rows.filter(r=>{const n=nC?r[nC]:null,p=pC?r[pC]:null;if(!n||!p)return false;if(n==="NAME"||n==="name")return false;return!isNaN(parseFloat(String(p).replace(/[$,]/g,"")));}).map(r=>{
    const bd=parseDate(bC?(r[bC]||""):""),ld=parseDate(ldC?(r[ldC]||""):"");
    return{name:nC?(r[nC]||"Unknown"):"Unknown",status:sC?(r[sC]||"Bound"):"Bound",boundDate:bC?(r[bC]||""):"",effectiveDate:eC?(r[eC]||""):"",price:pC?(parseFloat(String(r[pC]||"0").replace(/[$,]/g,""))||0):0,platform:plC?(r[plC]||"Unknown"):"Unknown",type:tC?(r[tC]||"Other"):"Other",policyNumber:poC?(r[poC]||""):"",referral:rC?!!(r[rC]&&String(r[rC]).trim().length>0):false,leadSource:lsC?(r[lsC]||""):"",review:rvC?(r[rvC]||""):"",daysToBindFromLead:daysBetween(ld,bd),boundDateObj:bd};
  });
}

/* ===== GAME ===== */
const revTiers=[{name:"Bronze",target:15000,icon:"🥉"},{name:"Silver",target:25000,icon:"🥈"},{name:"Gold",target:40000,icon:"🥇"},{name:"Platinum",target:60000,icon:"💎"},{name:"Diamond",target:100000,icon:"👑"}];
const polTiers=[{name:"Starter",target:5,icon:"🌱"},{name:"Hustler",target:10,icon:"🔥"},{name:"Closer",target:15,icon:"⚡"},{name:"Machine",target:25,icon:"🤖"},{name:"Legend",target:40,icon:"🏆"}];
function getTier(tiers,v){let c=null,n=tiers[0];for(let i=0;i<tiers.length;i++){if(v>=tiers[i].target){c=tiers[i];n=tiers[i+1]||null;}else{n=tiers[i];break;}}return{current:c,next:n};}
function getBadges(s){const n=s.length,r=s.reduce((a,p)=>a+p.price,0),ty=[...new Set(s.map(x=>x.type))],pl=[...new Set(s.map(x=>x.platform))],mo=[...new Set(s.map(x=>{const p=x.boundDate.split("/");return p.length>=2?p[0]:"";}).filter(Boolean))],li=s.filter(x=>x.type.toLowerCase().includes("life")),co=s.filter(x=>x.type.toLowerCase().includes("commercial"));return[{name:"First Blood",desc:"Bind first policy",earned:n>=1,icon:"🎯"},{name:"High Roller",desc:"$5K+ policy",earned:s.some(x=>x.price>=5000),icon:"💰"},{name:"Whale Hunter",desc:"$10K+ policy",earned:s.some(x=>x.price>=10000),icon:"🐋"},{name:"Diversified",desc:"5+ types",earned:ty.length>=5,icon:"🎨"},{name:"Platform Master",desc:"5+ platforms",earned:pl.length>=5,icon:"🌐"},{name:"Referral King",desc:"Referral deal",earned:s.some(x=>x.referral),icon:"🤝"},{name:"Commercial Crusher",desc:"Commercial policy",earned:co.length>=1,icon:"🏢"},{name:"Safety First",desc:"Workers Comp",earned:s.some(x=>x.type.toLowerCase().includes("workers")),icon:"🦺"},{name:"Double Digit",desc:"10+ policies",earned:n>=10,icon:"🔟"},{name:"Back-to-Back",desc:"2+ months",earned:mo.length>=2,icon:"📅"},{name:"$25K Club",desc:"$25K premium",earned:r>=25000,icon:"💵"},{name:"Hat Trick",desc:"3+ in a week",earned:n>=3,icon:"🎩"},{name:"Life Saver",desc:"3 life policies",earned:li.length>=3,icon:"❤️"},{name:"Commercial King",desc:"5 commercial",earned:co.length>=5,icon:"🏙️"},{name:"Speed Demon",desc:"Avg bind <7d",earned:(()=>{const d=s.filter(x=>x.daysToBindFromLead!==null);return d.length>0&&(d.reduce((a,x)=>a+x.daysToBindFromLead,0)/d.length)<7;})(),icon:"⚡"},{name:"$75K Legend",desc:"$75K premium",earned:r>=75000,icon:"🔥"}];}
function calcXP(s){let xp=0;s.forEach(x=>{xp+=100;if(x.price>=5000)xp+=200;if(x.price>=10000)xp+=300;if(x.referral)xp+=150;if(x.type.toLowerCase().includes("commercial"))xp+=100;if(x.type.toLowerCase().includes("life"))xp+=120;});xp+=getBadges(s).filter(a=>a.earned).length*250;return xp;}
const xpLevels=[{level:1,xp:0},{level:2,xp:1000},{level:3,xp:2500},{level:4,xp:4500},{level:5,xp:7000},{level:6,xp:10000},{level:7,xp:14000},{level:8,xp:19000},{level:9,xp:25000},{level:10,xp:35000}];
function getLevel(xp){let l=xpLevels[0],n=xpLevels[1];for(let i=0;i<xpLevels.length;i++){if(xp>=xpLevels[i].xp){l=xpLevels[i];n=xpLevels[i+1]||null;}}return{current:l,next:n};}
function getStreak(s){if(!s.length)return{current:0,best:0};const d=s.map(x=>x.boundDateObj).filter(Boolean).sort((a,b)=>a-b);if(!d.length)return{current:0,best:0};const gw=d=>{const j=new Date(d.getFullYear(),0,1);return`${d.getFullYear()}-W${Math.ceil(((d-j)/86400000+j.getDay()+1)/7)}`;};const w=[...new Set(d.map(gw))].sort();let st=1,b=1;for(let i=1;i<w.length;i++){const[y1,w1]=w[i-1].split("-W").map(Number),[y2,w2]=w[i].split("-W").map(Number);if((y1===y2&&w2===w1+1)||(y2===y1+1&&w1>=52&&w2===1))st++;else st=1;b=Math.max(b,st);}return{current:st,best:b};}

const fmtPrice=v=>"$"+v.toLocaleString("en-US",{minimumFractionDigits:2});
const fmtPD=d=>{if(!d)return"";const dt=new Date(d+"T00:00:00");return(dt.getMonth()+1)+"/"+dt.getDate()+"/"+dt.getFullYear();};
const rankEmojis=["👑","🥈","🥉","4️⃣","5️⃣","6️⃣","7️⃣","8️⃣"];
const barColors=["#6366f1","#059669","#d97706","#dc2626","#7c3aed","#0891b2","#db2777","#0d9488"];

/* ===== CONFETTI ===== */
function useConfetti(){const c=useRef(null),p=useRef([]),f=useRef(null);const launch=useCallback(()=>{const cv=c.current;if(!cv)return;const ctx=cv.getContext("2d");cv.width=window.innerWidth;cv.height=window.innerHeight;const cols=["#6366f1","#ec4899","#f59e0b","#10b981","#ef4444","#8b5cf6","#06b6d4"];for(let i=0;i<120;i++)p.current.push({x:Math.random()*cv.width,y:-20-Math.random()*400,w:6+Math.random()*6,h:4+Math.random()*4,color:cols[Math.floor(Math.random()*cols.length)],vx:(Math.random()-0.5)*6,vy:2+Math.random()*4,rot:Math.random()*360,rs:(Math.random()-0.5)*12,life:1,decay:0.003+Math.random()*0.004});const anim=()=>{ctx.clearRect(0,0,cv.width,cv.height);p.current=p.current.filter(x=>x.life>0);p.current.forEach(x=>{x.x+=x.vx;x.vy+=0.08;x.y+=x.vy;x.rot+=x.rs;x.life-=x.decay;ctx.save();ctx.translate(x.x,x.y);ctx.rotate(x.rot*Math.PI/180);ctx.globalAlpha=x.life;ctx.fillStyle=x.color;ctx.fillRect(-x.w/2,-x.h/2,x.w,x.h);ctx.restore();});if(p.current.length>0)f.current=requestAnimationFrame(anim);};if(f.current)cancelAnimationFrame(f.current);anim();},[]);return{canvasRef:c,launch};}

function MiniBar({value,max,color,height=8,T}){const pct=max>0?Math.min((value/max)*100,100):0;return <div style={{width:"100%",height,background:T.bgSubtle,borderRadius:height/2,overflow:"hidden"}}><div style={{width:`${pct}%`,height:"100%",background:color,borderRadius:height/2,transition:"width 1.2s"}}/></div>;}

/* ===== MODAL ===== */
function Modal({children,onClose,T}){return <div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,0.55)",zIndex:10000,display:"flex",alignItems:"center",justifyContent:"center",padding:20}} onClick={onClose}><div onClick={e=>e.stopPropagation()} style={{background:T.bgCard,borderRadius:20,padding:28,maxWidth:650,width:"100%",maxHeight:"85vh",overflow:"auto",boxShadow:"0 20px 60px rgba(0,0,0,0.3)",color:T.text}}>{children}</div></div>;}

function UserGuide({onClose,T}){
  return <Modal onClose={onClose} T={T}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}><h2 style={{fontSize:20,fontWeight:800}}>📖 User's Guide</h2><button onClick={onClose} style={{background:"none",border:"none",fontSize:24,cursor:"pointer",color:T.textMuted}}>×</button></div>
    <div style={{fontSize:13,lineHeight:1.8,color:T.textSec}}>
      <h3 style={{fontSize:15,fontWeight:700,marginTop:12,color:T.text}}>🚀 Getting Started</h3>
      <p>This dashboard tracks your agency's sales performance in real-time from Google Sheets. Each producer has their own tab.</p>
      <h3 style={{fontSize:15,fontWeight:700,marginTop:12,color:T.text}}>📊 Dashboard Tabs</h3>
      <p><strong>Dashboard</strong> — Overview with premium, policies, streaks, recent wins.<br/>
      <strong>Leaderboard</strong> — Revenue rankings with race cars (premium) and horses (policies). The #1 producer shows "LEADER".<br/>
      <strong>Badges</strong> — 16 achievement badges earned by milestones.<br/>
      <strong>Breakdown</strong> — Premium by type, platform, lead source, top deals.<br/>
      <strong>Quests</strong> — Goal-based challenges with XP rewards.<br/>
      <strong>Reviews</strong> — Customer reviews pulled from spreadsheet with premium and policy counts.</p>
      <h3 style={{fontSize:15,fontWeight:700,marginTop:12,color:T.text}}>📅 Contest Periods</h3>
      <p>Click "⚙️ Periods" to define contest windows. Dashboard filters data by selected period. Auto-detects current period.</p>
      <h3 style={{fontSize:15,fontWeight:700,marginTop:12,color:T.text}}>🎨 Personalization</h3>
      <p><strong>Avatars</strong> — Click your avatar to choose from 24 options.<br/>
      <strong>Sounds</strong> — Each producer has a unique policy-bound sound (set in Admin).<br/>
      <strong>Dark Mode</strong> — Toggle with 🌙/☀️ button.</p>
      <h3 style={{fontSize:15,fontWeight:700,marginTop:12,color:T.text}}>👤 Admin Panel (🔐)</h3>
      <p>Add/remove producers, set names, GIDs, separate spreadsheet IDs, avatars, colors, sounds.</p>
      <h3 style={{fontSize:15,fontWeight:700,marginTop:12,color:T.text}}>🏎️ Race Tracks</h3>
      <p><strong>Premium Race</strong> — Race cars show each producer's premium position. Car furthest right is leading.<br/>
      <strong>Policy Derby</strong> — Horses gallop based on policy count.</p>
      <h3 style={{fontSize:15,fontWeight:700,marginTop:12,color:T.text}}>🔄 Data</h3>
      <p>Auto-refreshes every 5 min. Manual refresh button available. New policy triggers confetti + sound.</p>
      <h3 style={{fontSize:15,fontWeight:700,marginTop:12,color:T.text}}>📱 Deployment</h3>
      <p>Host on Netlify (free): drag folder with index.html → get shareable link for team.</p>
    </div>
  </Modal>;
}

function AdminPanel({agentsCfg,onSave,onClose,T}){
  const[ed,setEd]=useState(agentsCfg.map(a=>({...a})));
  const colors=["#6366f1","#db2777","#0891b2","#d97706","#059669","#7c3aed","#dc2626","#0d9488","#ea580c","#4f46e5"];
  const add=()=>setEd([...ed,{id:"a_"+Date.now(),name:"",avatar:"👨‍💼",color:colors[ed.length%colors.length],gid:"0",sheetId:"",sound:"chime"}]);
  const rm=i=>setEd(ed.filter((_,j)=>j!==i));
  const upd=(i,f,v)=>{const n=[...ed];n[i]={...n[i],[f]:v};setEd(n);};
