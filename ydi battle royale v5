/* ===== RACE TRACKS ===== */
function RaceTrack({agents,field,maxVal,icon,title,T}){
  const sorted=[...agents].sort((a,b)=>(b[field]||0)-(a[field]||0));
  return <div style={{background:T.bgCard,borderRadius:16,padding:20,border:`1px solid ${T.border}`,marginBottom:16,boxShadow:T.shadow}}>
    <div style={{fontSize:14,fontWeight:700,marginBottom:14}}>{title}</div>
    {sorted.map((a,i)=>{const val=a[field]||0;const pct=maxVal>0?Math.min((val/maxVal)*100,100):0;
      return <div key={a.id} style={{marginBottom:12}}>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:11,marginBottom:4,color:T.textSec}}>
          <span style={{fontWeight:700,color:a.color}}>{a.avatar} {a.name.split(" ")[0]}{i===0&&val>0?" — LEADER":""}</span>
          <span style={{fontWeight:700}}>{field==="totalRevenue"?fmtPrice(val):val+" policies"}</span>
        </div>
        <div style={{position:"relative",height:28,background:T.bgSubtle,borderRadius:14,overflow:"hidden"}}>
          <div style={{width:`${Math.max(pct,4)}%`,height:"100%",background:`linear-gradient(90deg, ${a.color}44, ${a.color})`,borderRadius:14,transition:"width 1.5s"}}/>
          <div style={{position:"absolute",right:`${100-Math.max(pct,4)}%`,top:"50%",transform:"translateY(-50%)",fontSize:20,animation:field==="totalRevenue"?"raceMove 0.6s infinite":"gallop 0.5s infinite",marginRight:-12}}>{icon}</div>
        </div>
      </div>;})}
  </div>;
}

