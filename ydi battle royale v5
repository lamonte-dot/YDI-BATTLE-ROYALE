        const parsed=Papa.parse(csv,{header:true,skipEmptyLines:true});const headers=parsed.meta.fields||[];const allSales=parseRows(parsed.data,headers);
        results.push({...ag,allSales,sales:allSales,totalRevenue:allSales.reduce((s,p)=>s+p.price,0),totalPolicies:allSales.length});
      }catch(e){results.push({...ag,allSales:[],sales:[],totalRevenue:0,totalPolicies:0});}
    }
    setAllData(results);
    const filtered=applyFilter(results,selPeriodIdx);
    const newTotal=filtered.reduce((s,a)=>s+a.totalPolicies,0);
    if(prevCount.current!==null&&newTotal>prevCount.current){
      for(const ag of filtered){const prev=prevAgents.current.find(a=>a.id===ag.id);
        if(prev&&ag.totalPolicies>prev.totalPolicies){const newest=ag.sales[ag.sales.length-1];
          if(newest){setNewPolicy({...newest,agentName:ag.name});playSound(ag.sound||"chime");launchConfetti();break;}}}
    }
    prevCount.current=newTotal;prevAgents.current=filtered;setAgents(filtered);setLastRefresh(new Date());setLoading(false);
  },[agentsCfg,applyFilter,selPeriodIdx,launchConfetti]);

  useEffect(()=>{if(allData.length>0){const f=applyFilter(allData,selPeriodIdx);setAgents(f);prevCount.current=f.reduce((s,a)=>s+a.totalPolicies,0);prevAgents.current=f;}},[selPeriodIdx,periods,allData,applyFilter]);
