        <select value={a.avatar} onChange={e=>upd(i,"avatar",e.target.value)} style={{padding:"8px",borderRadius:8,border:`1px solid ${T.border}`,fontSize:18,background:T.bgCard}}>{AVATAR_OPTIONS.map(av=><option key={av} value={av}>{av}</option>)}</select>
        <input type="color" value={a.color} onChange={e=>upd(i,"color",e.target.value)} style={{width:36,height:36,border:"none",borderRadius:8,cursor:"pointer"}}/>
