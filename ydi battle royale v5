      <button onClick={()=>{onSave(ed.filter(p=>p.name&&p.start&&p.end));onClose();}} style={{flex:1,padding:12,borderRadius:12,border:"none",background:"#6366f1",color:"#fff",fontSize:13,fontWeight:700,cursor:"pointer"}}>💾 Save Periods</button>
