      </div>
      <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
        <input value={a.gid} onChange={e=>upd(i,"gid",e.target.value)} placeholder="Sheet Tab GID" style={{flex:1,minWidth:100,padding:"6px 10px",borderRadius:8,border:`1px solid ${T.border}`,fontSize:12,background:T.bgCard,color:T.text}}/>
        <input value={a.sheetId||""} onChange={e=>upd(i,"sheetId",e.target.value)} placeholder="Separate Sheet ID (optional)" style={{flex:2,minWidth:150,padding:"6px 10px",borderRadius:8,border:`1px solid ${T.border}`,fontSize:12,background:T.bgCard,color:T.text}}/>
        <select value={a.sound} onChange={e=>upd(i,"sound",e.target.value)} style={{padding:"6px",borderRadius:8,border:`1px solid ${T.border}`,fontSize:12,background:T.bgCard,color:T.text}}>{SOUND_OPTIONS.map(s=><option key={s.id} value={s.id}>{s.name}</option>)}</select>
        <button onClick={()=>playSound(a.sound)} style={{padding:"6px 8px",borderRadius:8,border:`1px solid ${T.border}`,background:T.bgCard,cursor:"pointer",fontSize:12}}>▶️</button>
      </div>
    </div>)}
    <button onClick={add} style={{width:"100%",padding:12,borderRadius:12,border:`2px dashed ${T.border}`,background:"transparent",color:T.textSec,fontSize:13,fontWeight:600,cursor:"pointer",marginBottom:16}}>+ Add Producer</button>
